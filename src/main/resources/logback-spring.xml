<?xml version="1.0" encoding="UTF-8"?>
<configuration>
  <!-- Inherit Spring Boot's default console appender and log-level wiring. -->
  <include resource="org/springframework/boot/logging/logback/base.xml"/>

  <springProperty name="appName" source="spring.application.name" defaultValue="computing_lab_may_2026"/>

  <!--
    Push logs to Loki in the loki profile (activated via SPRING_PROFILES_ACTIVE=dev,loki).
    The appender is non-blocking: batches are shipped asynchronously so a Loki outage
    never stalls request processing.

    Loki4j 2.x API differences from 1.x:
      - No <format> wrapper; top-level <labels>, <message>, <structuredMetadata>
      - <labels> is newline-separated key=value pairs (KV_PAIR_SEPARATOR = regex:\n|\r)
        Comma-separated pairs are NOT supported and throw IllegalArgumentException
      - <message> is a Logback Layout (PatternLayout here)
  -->
  <!--
    Suppress the per-request GRAPHQL_REQUEST line from the console when Loki is not
    active. When the loki profile IS active the root logger below points exclusively at
    the Loki appender, so this block is not reached and the interceptor's messages flow
    to Loki as normal.
  -->
  <springProfile name="!loki">
    <logger name="at.mavila.computing_lab_may_2026.infrastructure.web.graphql.GraphQlRequestLoggingInterceptor"
            level="OFF"/>
  </springProfile>

  <springProfile name="loki">
    <appender name="LOKI" class="com.github.loki4j.logback.Loki4jAppender">
      <http>
        <url>http://loki:3100/loki/api/v1/push</url>
        <connectionTimeoutMs>1000</connectionTimeoutMs>
        <requestTimeoutMs>3000</requestTimeoutMs>
      </http>
      <labels>
service=${appName}
level=%level
      </labels>
      <message class="ch.qos.logback.classic.PatternLayout">
        <pattern>%d{yyyy-MM-dd HH:mm:ss.SSS} %-5level [%thread] %logger{36} - %msg%n</pattern>
      </message>
    </appender>

    <root level="INFO">
      <appender-ref ref="LOKI"/>
    </root>
  </springProfile>

</configuration>
