        <!-- Actuator / Micrometer -->
        <mxCell id="actuator"
          value="&lt;b&gt;Spring Actuator + Micrometer&lt;/b&gt;&lt;br/&gt;Auto-instruments: JVM heap · GC · CPU · thread count&lt;br/&gt;HTTP: request count · latency histograms&lt;br/&gt;SLO buckets: 1 · 5 · 10 · 25 · 50 · 100 ms&lt;br/&gt;HikariCP pool · Tomcat connections&lt;br/&gt;Virtual threads enabled&lt;br/&gt;Exposes: /actuator/prometheus · /actuator/health · /actuator/metrics"
          style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;fontSize=10;"
          vertex="1" parent="obs">
          <mxGeometry x="20" y="48" width="600" height="110" as="geometry" />
        </mxCell>

        <!-- logback-spring.xml -->
        <mxCell id="logback"
          value="&lt;b&gt;logback-spring.xml&lt;/b&gt;&lt;br/&gt;&lt;springProfile name=&amp;quot;loki&amp;quot;&gt; activates Loki4jAppender&lt;br/&gt;GraphQlRequestLoggingInterceptor logger: additivity=false&lt;br/&gt;→ GRAPHQL_REQUEST lines go to Loki only, never to console&lt;br/&gt;To run both: spring.profiles.active=dev,loki"
          style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=10;"
          vertex="1" parent="obs">
          <mxGeometry x="20" y="196" width="600" height="90" as="geometry" />
        </mxCell>

        <!-- Loki -->
        <mxCell id="loki"
          value="&lt;b&gt;Grafana Loki&lt;/b&gt;&lt;br/&gt;Receives structured log push via Loki4j&lt;br/&gt;Log format: GRAPHQL_REQUEST key=&amp;quot;value&amp;quot; pairs&lt;br/&gt;Fields: remoteIp · uri · document · variables&lt;br/&gt;Queryable in Grafana via LogQL"
          style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;fontSize=10;"
          vertex="1" parent="obs">
          <mxGeometry x="20" y="330" width="600" height="100" as="geometry" />
        </mxCell>

        <!-- Prometheus -->
        <mxCell id="prometheus"
          value="&lt;b&gt;Prometheus&lt;/b&gt;&lt;br/&gt;Scrapes /actuator/prometheus on configured interval&lt;br/&gt;Stores time-series: JVM heap · GC pauses · CPU usage&lt;br/&gt;HTTP request latency (p50 / p95 / p99) · error rate&lt;br/&gt;HikariCP pool saturation · SLO compliance"
          style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;fontSize=10;"
          vertex="1" parent="obs">
          <mxGeometry x="20" y="478" width="600" height="100" as="geometry" />
        </mxCell>

        <!-- Grafana -->
        <mxCell id="grafana"
          value="&lt;b&gt;Grafana Dashboard&lt;/b&gt;&lt;br/&gt;Prometheus datasource → JVM heap trend · CPU % · request latency (p50 / p95 / p99)&lt;br/&gt;error rate · HikariCP pool · SLO compliance panels&lt;br/&gt;Loki datasource → GRAPHQL_REQUEST log stream explorer · LogQL&lt;br/&gt;&lt;br/&gt;Demo: BAD mode → CPU spike + upward heap slope visible immediately&lt;br/&gt;           GOOD mode → all graphs return to flat baseline"
          style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;fontSize=10;"
          vertex="1" parent="obs">
          <mxGeometry x="20" y="626" width="600" height="130" as="geometry" />
        </mxCell>

