                 whiteSpace=wrap;fontSize=17;fontStyle=1;"
          vertex="1" parent="1">
          <mxGeometry x="20" y="20" width="1150" height="40" as="geometry" />
        </mxCell>

        <!-- ══════════════════════════════════════════════════════════
             CLIENT
             ══════════════════════════════════════════════════════════ -->
        <mxCell id="client" value="&lt;b&gt;GraphQL Consumer&lt;/b&gt;&lt;br/&gt;GraphiQL IDE (/graphiql in dev) · any HTTP client · load generator"
          style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;
                 fontColor=#333333;fontSize=11;"
          vertex="1" parent="1">
          <mxGeometry x="330" y="80" width="530" height="60" as="geometry" />
        </mxCell>

        <!-- ══════════════════════════════════════════════════════════
             INFRASTRUCTURE LAYER
             ══════════════════════════════════════════════════════════ -->
        <mxCell id="infra" value="INFRASTRUCTURE  ·  at.mavila.computing_lab_may_2026.infrastructure"
          style="swimlane;startSize=30;fillColor=#dae8fc;strokeColor=#6c8ebf;
                 fontStyle=1;fontSize=12;align=left;rounded=1;"
          vertex="1" parent="1">
          <mxGeometry x="20" y="185" width="1150" height="390" as="geometry" />
        </mxCell>

        <!-- Interceptor — spans full width -->
        <mxCell id="interceptor"
          value="&lt;b&gt;GraphQlRequestLoggingInterceptor&lt;/b&gt;  ·  implements WebGraphQlInterceptor  (fires on real HTTP transport only — GraphQlTester bypasses this)&lt;br/&gt;
Logs per request: remoteIp [resolution order: X-Forwarded-For → X-Real-IP → raw socket → &amp;quot;unknown&amp;quot;] · uri · document · variables&lt;br/&gt;
Payload truncated at 500 chars · __schema introspection skipped · Level=OFF in dev profile · Level=INFO + Loki4j routing when loki profile active"
          style="rounded=1;whiteSpace=wrap;html=1;fillColor=#bdd7ee;strokeColor=#6c8ebf;fontSize=10;"
          vertex="1" parent="infra">
          <mxGeometry x="20" y="48" width="1110" height="72" as="geometry" />
        </mxCell>

        <!-- ArithmeticController -->
        <mxCell id="controller"
          value="&lt;b&gt;ArithmeticController&lt;/b&gt;&lt;br/&gt;@Controller&lt;br/&gt;@QueryMapping methods:&lt;br/&gt;  add · subtract · multiply · divide&lt;br/&gt;@Argument(&amp;quot;a&amp;quot;) @Argument(&amp;quot;b&amp;quot;) always explicit&lt;br/&gt;No business logic — pure GraphQL adapter"
          style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=10;"
          vertex="1" parent="infra">
          <mxGeometry x="20" y="148" width="280" height="130" as="geometry" />
        </mxCell>

        <!-- GraphQLExceptionHandler -->
        <mxCell id="exhandler"
          value="&lt;b&gt;GraphQLExceptionHandler&lt;/b&gt;&lt;br/&gt;extends DataFetcherExceptionResolverAdapter&lt;br/&gt;&lt;br/&gt;DivisionByZeroException&lt;br/&gt;→ BAD_REQUEST  errorCode: DIVISION_BY_ZERO&lt;br/&gt;&lt;br/&gt;IllegalArgumentException&lt;br/&gt;→ BAD_REQUEST  errorCode: INVALID_ARGUMENT&lt;br/&gt;&lt;br/&gt;null → Spring default → INTERNAL_ERROR"
          style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=10;"
          vertex="1" parent="infra">
          <mxGeometry x="330" y="148" width="300" height="200" as="geometry" />
        </mxCell>

        <!-- GraphQLConfig -->
        <mxCell id="gqlconfig"
          value="&lt;b&gt;GraphQLConfig&lt;/b&gt;&lt;br/&gt;@Configuration&lt;br/&gt;&lt;br/&gt;Registers BigDecimal scalar&lt;br/&gt;ExtendedScalars.GraphQLBigDecimal&lt;br/&gt;&lt;br/&gt;Accepts:&lt;br/&gt;  3   (bare int)&lt;br/&gt;  3.14  (bare float)&lt;br/&gt;  &amp;quot;3.14&amp;quot;  (quoted string)&lt;br/&gt;&lt;br/&gt;Add new scalars here"
          style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=10;"
          vertex="1" parent="infra">
          <mxGeometry x="660" y="148" width="210" height="220" as="geometry" />
        </mxCell>

        <!-- schema.graphqls -->
        <mxCell id="schema"
          value="&lt;b&gt;schema.graphqls&lt;/b&gt;&lt;br/&gt;src/main/resources/graphql/&lt;br/&gt;&lt;br/&gt;type Query {&lt;br/&gt;  add(a: BigDecimal!, b: BigDecimal!): BigDecimal!&lt;br/&gt;  subtract(...)&lt;br/&gt;  multiply(...)&lt;br/&gt;  divide(...)&lt;br/&gt;}&lt;br/&gt;scalar BigDecimal"
          style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=10;"
          vertex="1" parent="infra">
          <mxGeometry x="900" y="148" width="230" height="210" as="geometry" />
        </mxCell>

        <!-- Endpoint quick-ref -->
        <mxCell id="endpoints"
          value="Endpoints:&lt;br/&gt;POST /graphql&lt;br/&gt;GET /graphiql (dev)&lt;br/&gt;GET /actuator/prometheus&lt;br/&gt;GET /actuator/health"
          style="shape=note;whiteSpace=wrap;html=1;backgroundOutline=1;size=16;
                 fillColor=#f5f5f5;strokeColor=#666666;fontSize=10;"
          vertex="1" parent="infra">
          <mxGeometry x="20" y="310" width="200" height="68" as="geometry" />
        </mxCell>

        <!-- ══════════════════════════════════════════════════════════
             APPLICATION LAYER
             ══════════════════════════════════════════════════════════ -->
        <mxCell id="app" value="APPLICATION  ·  at.mavila.computing_lab_may_2026.application"
          style="swimlane;startSize=30;fillColor=#d5e8d4;strokeColor=#82b366;
                 fontStyle=1;fontSize=12;align=left;rounded=1;"
          vertex="1" parent="1">
          <mxGeometry x="20" y="625" width="1150" height="110" as="geometry" />
        </mxCell>

        <mxCell id="service"
          value="&lt;b&gt;CalculatorService&lt;/b&gt;  ·  @Service · @RequiredArgsConstructor&lt;br/&gt;Pure delegation — add · subtract · multiply · divide → Calculator&lt;br/&gt;Null defaulting via Objects.isNull() permitted here (only layer that may do this)"
          style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=10;"
          vertex="1" parent="app">
          <mxGeometry x="175" y="38" width="800" height="60" as="geometry" />
        </mxCell>

        <!-- ══════════════════════════════════════════════════════════
             DOMAIN LAYER
             ══════════════════════════════════════════════════════════ -->
        <mxCell id="domain" value="DOMAIN  ·  at.mavila.computing_lab_may_2026.domain"
          style="swimlane;startSize=30;fillColor=#e1d5e7;strokeColor=#9673a6;
                 fontStyle=1;fontSize=12;align=left;rounded=1;"
          vertex="1" parent="1">
          <mxGeometry x="20" y="785" width="1150" height="220" as="geometry" />
        </mxCell>

        <mxCell id="calculator"
          value="&lt;b&gt;Calculator&lt;/b&gt;  ·  @Component · @Validated&lt;br/&gt;All params @NotNull final — constraint enforced via Spring AOP&lt;br/&gt;&lt;br/&gt;add(a, b)      → a.add(b)&lt;br/&gt;subtract(a, b) → a.subtract(b)&lt;br/&gt;multiply(a, b) → a.multiply(b)&lt;br/&gt;divide(a, b)   → a.divide(b, scale=10, HALF_UP)  throws DivisionByZeroException if b = 0&lt;br/&gt;&lt;br/&gt;BigDecimal — arbitrary precision, no floating-point rounding errors · O(n) time, O(n) space"
          style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=10;"
          vertex="1" parent="domain">
          <mxGeometry x="20" y="42" width="630" height="158" as="geometry" />
        </mxCell>

        <mxCell id="exception"
          value="&lt;b&gt;DivisionByZeroException&lt;/b&gt;&lt;br/&gt;package: domain/arithmetic/exception/&lt;br/&gt;extends RuntimeException&lt;br/&gt;msg: &amp;quot;Division by zero is not allowed&amp;quot;&lt;br/&gt;&lt;br/&gt;Thrown by Calculator.divide()&lt;br/&gt;Mapped by GraphQLExceptionHandler"
          style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=10;"
          vertex="1" parent="domain">
          <mxGeometry x="680" y="42" width="280" height="158" as="geometry" />
        </mxCell>

        <!-- Demo toggle note -->
        <mxCell id="demotoggle"
          value="&lt;b&gt;⚑ Demo toggle&lt;/b&gt;&lt;br/&gt;./toggle-calculator.sh good|bad&lt;br/&gt;bad  → fibonacci(35) CPU burn&lt;br/&gt;         + unbounded static list (heap leak)&lt;br/&gt;good → clean implementation&lt;br/&gt;Results stay correct in both modes"
          style="shape=note;whiteSpace=wrap;html=1;backgroundOutline=1;size=16;
                 fillColor=#fff2cc;strokeColor=#d6b656;fontSize=10;"
          vertex="1" parent="domain">
          <mxGeometry x="990" y="42" width="140" height="158" as="geometry" />
        </mxCell>

